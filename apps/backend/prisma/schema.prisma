generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Widget {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("google_reviews")
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
