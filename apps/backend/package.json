{
  "name": "web-widget-tool-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && npm run build:widget",
    "build:widget": "esbuild src/widget/index.ts --bundle --minify --outfile=public/widget.js --platform=browser --target=es2017",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.0.0",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "better-auth": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "nodemailer": "^6.9.9",
    "stripe": "^14.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.5",
    "@types/nodemailer": "^6.4.14",
    "esbuild": "^0.20.1",
    "prisma": "^5.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
