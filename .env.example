# ================================================================
# WebWidget Tool — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs.
# ================================================================

# ----------------------------------------------------------------
# Mode de l'application
# selfhosted : un seul admin via ADMIN_EMAIL/ADMIN_PASSWORD, pas de Stripe ni SMTP requis
# saas       : gestion multi-utilisateurs, Stripe, Better Auth
# ----------------------------------------------------------------
APP_MODE=selfhosted

# ----------------------------------------------------------------
# Admin (mode selfhosted uniquement)
# ----------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# ----------------------------------------------------------------
# Sécurité
# Générez une clé aléatoire en production : openssl rand -hex 32
# ----------------------------------------------------------------
JWT_SECRET=supersecretkey_change_in_production

# ----------------------------------------------------------------
# Google Places API
# Clé API Google Maps avec l'API Places activée
# ----------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# Durée du cache des avis Google en secondes (défaut : 7 jours)
GOOGLE_REVIEWS_CACHE_TTL=604800

# ----------------------------------------------------------------
# SMTP (requis si APP_MODE=saas, ou si des widgets envoient des emails)
# ----------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="WebWidget <noreply@mondomaine.com>"

# ----------------------------------------------------------------
# Better Auth (requis si APP_MODE=saas)
# ----------------------------------------------------------------
BETTER_AUTH_SECRET=         # openssl rand -hex 32
BETTER_AUTH_URL=            # URL publique du backend, ex: https://api.monsite.com

# OAuth providers (optionnel, si APP_MODE=saas)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Superadmin backoffice (email du compte qui aura accès au /admin)
SUPERADMIN_EMAIL=

# ----------------------------------------------------------------
# Stripe (requis si APP_MODE=saas)
# ----------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=       # price_xxx depuis le dashboard Stripe
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ================================================================
# compose.dev.yml — développement (build local, 3 conteneurs)
# ================================================================
VITE_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ================================================================
# compose.prod.yml — production
# ================================================================
APP_URL=http://localhost:3000
PORT=4000
FRONTEND_PORT=3000
POSTGRES_PASSWORD=changeme
POSTGRES_USER=postgres
